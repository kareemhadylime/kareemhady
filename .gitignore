# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example committed; ignore the real secrets)
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
# vercel env pull writes these â€” they contain prod secrets
.env.production
.env.development
.env.preview

# vercel
.vercel

# claude code worktrees
.claude/worktrees/

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.claude/Documents/
.claude/scheduled_tasks.lock
.superpowers/
.env*.local

# Operator-local source documents. Contains sensitive financial data
# (broker statements, partner ledgers, P&Ls). Never commit.
/Lime Domains/

# One-off operator scripts (audit reconciliation, etc.). Often contain
# embedded credentials or environment-specific paths.
/scripts/audit-stocks.*

# Stray duplicate of public/brand/xlabel — keep the canonical /public/brand/xlabel/
/public/brand/xlabel branding/
