# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Security
TOKEN_ENCRYPTION_KEY=
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic (Phase 2)
ANTHROPIC_API_KEY=

# Stripe (Phase 5.8 — Beithady Payouts API reconciliation)
# Use a Restricted key with read-only scopes: Charges, PaymentIntents, Refunds,
# Customers, Balance transactions, Payouts. Never commit. Rotate via Developers → API keys.
STRIPE_SECRET_KEY=

# Guesty PRO Open API (Phase 6 — live bookings / listings / reviews / messages / payouts)
# Create in Guesty → Integrations → Marketplace → API → "New secret token" (scope: open-api).
# Token TTL 24h, auto-refreshed in src/lib/guesty.ts via client_credentials grant.
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=
GUESTY_ACCOUNT_ID=
# Webhook secret for /api/webhook/guesty/conversation — Phase O real-time
# conversation events. Required for the inbox to refresh in real-time
# instead of waiting for the daily cron. Generate with:
#   openssl rand -hex 32
# Then in Guesty → Settings → Webhooks, configure the URL as:
#   https://limeinc.vercel.app/api/webhook/guesty/conversation?secret=<this value>
# Subscribe at minimum to: reservation.messageReceived + reservation.messageSent
GUESTY_WEBHOOK_SECRET=

# Odoo 18 (Phase 7 — finance closure: invoices, bills, expenses, per-property P&L)
# Auth: JSON-RPC + API key. Create the key at:
#   Profile (top-right avatar) → My Profile → Account Security → New API Key
# Prefer a dedicated "API Bot" user with scoped read-only access to Accounting
# over your personal admin login. URL is the root (no /odoo suffix); DB name
# is the subdomain for Odoo Online (e.g. fmplus.odoo.com → ODOO_DB=fmplus).
ODOO_URL=
ODOO_DB=
ODOO_USER=
ODOO_API_KEY=

# Shopify (Phase 10 — Kika kika-swim-wear storefront for women's garments)
# Two auth options:
#   A) Legacy custom-app token (simplest if your store still allows it):
#      set SHOPIFY_ADMIN_ACCESS_TOKEN to the shpat_... from Settings →
#      Apps → Develop apps → your app → API credentials.
#   B) Modern Dev Dashboard OAuth flow (required on stores where the
#      legacy path redirects to Dev Dashboard): create a Dev Dashboard
#      app, set SHOPIFY_APP_CLIENT_ID + SHOPIFY_APP_CLIENT_SECRET below,
#      then visit /api/shopify/auth/start once to install it. The offline
#      access token is persisted in the integration_tokens table.
# Either way: set SHOPIFY_STORE_DOMAIN to the short handle (e.g.
# 'kika-swim-wear' → resolves to kika-swim-wear.myshopify.com).
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=

# PriceLabs (Phase 8 — dynamic pricing: rate recommendations, min-stay,
# market context). Free on every paid plan; no separate tier. Generate the
# key at Account → Profile → API. Rate limit ~60 req/min per key; one key
# per account. PriceLabs exposes NO webhooks, so Phase 8 is pull-only.
PRICELABS_API_KEY=

# =====================================================================
# Phase H+: Multi-platform ads (Meta CTWA + Google + TikTok + IG Reels)
# =====================================================================

# Meta Lead Ads webhook verify token — set in Meta App → Webhooks → Page
# → leadgen field. Random string of your choice (must match the value
# entered in Meta's portal).
META_LEAD_FORM_WEBHOOK_VERIFY_TOKEN=

# Google Ads API (campaign creation + insights). All app-level creds also
# storable via /admin/integrations (provider google_ads). The redirect URI
# must match the one configured in the Google Cloud OAuth client.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_OAUTH_REDIRECT_URI=https://app.limeinc.cc/api/auth/google-ads/callback

# TikTok Business + Content Posting API. App credentials from
# developers.tiktok.com → app → Basic info. Marketing access token from
# Business Center → Apps → Generate token (long-lived).
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_OAUTH_REDIRECT_URI=https://app.limeinc.cc/api/auth/tiktok/callback
TIKTOK_LEAD_WEBHOOK_VERIFY_TOKEN=
